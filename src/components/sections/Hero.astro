---
import Button from '../ui/Button.astro';
import { Image } from 'astro:assets';
import heroPerfil from '../../assets/images/hero-perfil.webp';
---

<section id="hero" class="hero-section section-fade-bottom" style="--fade-to: #0A0A0A;">
  <!-- Efeitos de Luz de Fundo Neon -->
  <div class="neon-light light-1"></div>
  <div class="neon-light light-2"></div>

  <div class="container hero-grid">
    <div class="hero-content">
      <h1 class="hero-title" id="hero-title">
        Construímos sua <br/>
        <span class="text-gradient">Máquina de Clientes</span>
      </h1>
      <p class="hero-subtitle" id="hero-subtitle">
        Páginas de alta conversão focadas em vendas. Sem templates prontos, engenharia de ponta para escalar o seu negócio.
      </p>
      <div class="hero-ctas" id="hero-ctas">
        <Button type="primary" href="#pricing" id="btn-hero-primary" class="btn-large">
          Quero minha Máquina
        </Button>
        <Button type="ghost" href="#social-proof" class="btn-large">
          Ver Resultados
        </Button>
      </div>
    </div>
    <div class="hero-visual" id="hero-image">
      <Image src={heroPerfil} alt="André - Especialista em Landing Pages" class="hero-img" loading="eager" fetchpriority="high" />
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 0 4rem;
    overflow: hidden;
    background-color: #010101;

    /* Scroll-driven dissolve defaults */
    --hero-opacity: 1;
    --hero-blur: 0px;
    --hero-scale: 1;
    --hero-translate-y: 0px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 0 1rem;
    position: relative;
    z-index: 10;
  }

  .hero-grid {
    display: grid;
    gap: 3rem;
    align-items: center;
    /* Dissolve com Blur — driven by JS custom properties */
    opacity: var(--hero-opacity);
    filter: blur(var(--hero-blur));
    transform: scale(var(--hero-scale)) translateY(var(--hero-translate-y));
    will-change: opacity, filter, transform;
    transform-origin: center top;
  }

  @media (min-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Textos */
  .hero-content {
    text-align: left;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-text-primary);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 4.5rem;
    }
  }

  .text-gradient {
    color: transparent;
    background-image: linear-gradient(to right, var(--color-primary-neon), #00A666);
    background-clip: text;
    -webkit-background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    max-width: 500px;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  :global(.btn-large) {
    font-size: 1.125rem !important;
    padding: 16px 32px !important;
  }

  /* Imagem visual */
  .hero-visual {
    position: relative;
  }

  .hero-img {
    width: 100%;
    height: auto;
  }

  /* Efeitos de Luz */
  .neon-light {
    position: absolute;
    border-radius: 50%;
    mix-blend-mode: screen;
    filter: blur(128px);
    opacity: 0.2;
    z-index: 1;
    transition: translate 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: translate, transform;
  }

  .light-1 {
    top: -10%;
    left: -10%;
    width: 500px;
    height: 500px;
    background-color: var(--color-primary-neon);
    translate: calc(var(--mouse-x) * -100px) calc(var(--mouse-y) * -100px);
    animation: float-neon 12s ease-in-out infinite alternate;
  }

  .light-2 {
    top: 5%;
    left: 5%;
    width: 400px;
    height: 400px;
    background-color: #00A666;
    translate: calc(var(--mouse-x) * 100px) calc(var(--mouse-y) * 100px);
    animation: float-neon 15s ease-in-out infinite alternate-reverse;
  }

  @keyframes float-neon {
    0% { transform: scale(1) translate(0, 0); }
    50% { transform: scale(1.2) translate(100px, -100px); }
    100% { transform: scale(0.8) translate(-100px, 100px); }
  }
</style>
