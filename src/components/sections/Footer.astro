<footer class="footer-section">
  <div class="container text-center">
    <div class="logo">
      <img
        src="/images/logo-horizontal.webp"
        alt="OCARECADEV Logo"
        style="height: 30px;"
      />
    </div>
    <p class="copyright">
      &copy; {new Date().getFullYear()} OCARECADEV. Todos os direitos reservados.
      Transformando cliques em clientes.
    </p>
  </div>
</footer>

<style>
  .footer-section {
    padding: 3rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    margin-top: 4rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 0 1rem;
  }

  .text-center {
    text-align: center;
  }

  .logo {
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: 0.1em;
    color: var(--color-text-primary);
    margin-bottom: 1rem;
  }

  .copyright {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }
</style>
