---
import GlassCard from '../ui/GlassCard.astro';
---

<section id="about" class="section-about">
  <div class="container">
    <div class="about-grid">
      <div class="about-image scroll-reveal">
        <div class="image-wrapper">
          <img src="/images/perfil.webp" alt="André - OCARECADEV" class="profile-img" />
          <div class="neon-glow"></div>
        </div>
      </div>
      
      <div class="about-content scroll-reveal delay-200">
        <h2 class="section-title">Sobre o Especialista</h2>
        <p class="about-desc">
          Olá, eu sou o <strong>André Luiz Ferreira</strong>, criador da <span class="text-neon">OCARECADEV</span>. 
          Minha missão é transformar "sites bonitinhos" em verdadeiras máquinas de conversão. 
        </p>
        <p class="about-desc">
          Com experiência profunda em desenvolvimento web e estratégias de alta performance, 
          ajudo negócios a escalarem seus resultados com páginas projetadas milimetricamente para vender.
        </p>
        
        <div class="stats-grid">
          <GlassCard class="stat-card" padding="1rem">
            <h3>+50</h3>
            <span>Projetos Lançados</span>
          </GlassCard>
          <GlassCard class="stat-card" padding="1rem">
            <h3>100%</h3>
            <span>Foco em ROI</span>
          </GlassCard>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-about {
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 0 1rem;
    position: relative;
    z-index: 10;
  }

  .about-grid {
    display: grid;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Imagem */
  .about-image {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .image-wrapper {
    position: relative;
    width: 300px;
    height: 300px;
    border-radius: 50%;
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    position: relative;
    z-index: 2;
    border: 3px solid var(--glass-border);
  }

  .neon-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    background-color: var(--color-primary-neon);
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.3;
    z-index: 1;
  }

  /* Conteúdo */
  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-text-primary);
    margin-bottom: 1.5rem;
  }

  .about-desc {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  :global(.stat-card) {
    text-align: center;
  }

  :global(.stat-card h3) {
    font-size: 2rem;
    color: var(--color-primary-neon);
    margin-bottom: 0.5rem;
  }

  :global(.stat-card span) {
    color: var(--color-text-secondary);
    font-weight: 600;
  }
</style>
