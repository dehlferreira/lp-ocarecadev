---
import GlassCard from '../ui/GlassCard.astro';
import Icon from '../ui/Icon.astro';

const steps = [
  {
    num: '01',
    icon: 'layout-template',
    title: 'Estrutura validada',
    desc: 'Usamos modelos que já funcionam',
  },
  {
    num: '02',
    icon: 'sliders-horizontal',
    title: 'Personalização',
    desc: 'Adaptamos para o seu negócio',
  },
  {
    num: '03',
    icon: 'rocket',
    title: 'Publicação rápida',
    desc: 'Seu site no ar em poucos dias',
  },
  {
    num: '04',
    icon: 'trending-up',
    title: 'Geração de leads',
    desc: 'Visitantes viram contatos no WhatsApp',
  },
];

const delays = ['delay-100', 'delay-200', 'delay-300', 'delay-400'];
---

<section id="como-funciona" class="section-how section-fade-top section-fade-bottom">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title scroll-animate">Um processo simples, direto e focado em <span class="text-neon">resultado</span></h2>
    </div>

    <div class="steps-grid">
      {steps.map((step, i) => (
        <GlassCard class={`step-card scroll-animate anim-scale ${delays[i]}`}>
          <div class="step-top">
            <span class="step-icon">
              <Icon name={step.icon} size={24} />
            </span>
            <span class="step-num">{step.num}</span>
          </div>
          <h3 class="step-title">{step.title}</h3>
          <p class="step-desc">{step.desc}</p>
        </GlassCard>
      ))}
    </div>
  </div>
</section>

<style>
  .section-how {
    padding: 4rem 0;
    position: relative;
    background-color: #0A0A0A;
  }

  @media (min-width: 768px) {
    .section-how {
      padding: 8rem 0;
    }
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 0 1rem;
    position: relative;
    z-index: 10;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text-primary);
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: 3rem;
    }
  }

  .steps-grid {
    display: grid;
    gap: 2rem;
    position: relative;
  }

  @media (min-width: 768px) {
    .steps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .steps-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  :global(.step-card) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 2rem !important;
    position: relative;
    overflow: visible;
  }

  .step-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    margin-bottom: 1.5rem;
  }

  /* Badge do ícone — quadrado arredondado com tint neon */
  .step-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    color: var(--color-primary-neon);
    background: rgba(0, 255, 157, 0.08);
    border: 1px solid rgba(0, 255, 157, 0.25);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.08),
      0 4px 16px rgba(0, 255, 157, 0.12);
  }

  /* Número preenchido com gradiente neon (substitui o text-stroke quebrado) */
  .step-num {
    font-size: 2.75rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
    color: transparent;
    background-image: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.18),
      rgba(0, 255, 157, 0.28)
    );
    background-clip: text;
    -webkit-background-clip: text;
    font-variant-numeric: tabular-nums;
  }

  /* Conector horizontal entre os cards (somente desktop 4-col) */
  @media (min-width: 1024px) {
    :global(.step-card)::after {
      content: '';
      position: absolute;
      top: calc(2rem + 26px); /* centro vertical do badge de 52px */
      right: -2rem;
      width: 2rem;
      height: 1px;
      background: linear-gradient(
        to right,
        rgba(0, 255, 157, 0.4),
        rgba(0, 255, 157, 0)
      );
      transform: translateY(-50%);
      pointer-events: none;
    }

    :global(.step-card):last-child::after {
      display: none;
    }
  }

  .step-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .step-desc {
    color: var(--color-text-secondary);
    font-size: 1rem;
  }
</style>
