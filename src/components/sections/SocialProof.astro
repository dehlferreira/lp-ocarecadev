---
import GlassCard from '../ui/GlassCard.astro';
import BeforeAfterMockup from '../ui/BeforeAfterMockup.astro';
import Icon from '../ui/Icon.astro';

const benefits = [
  'Mais mensagens no WhatsApp',
  'Mais pedidos de orçamento',
  'Mais <span class="text-neon">clientes</span> entrando todos os dias',
];

const testimonials = [
  {
    initials: 'RA',
    placeholder: 'placeholder-0',
    name: 'Roberto Almeida',
    role: 'CEO, TechGrowth',
    text: '"Nossas conversões dobraram na primeira semana após o lançamento. O design e a velocidade da página são absurdos."',
    anim: 'anim-left',
    delay: 'delay-200',
  },
  {
    initials: 'MC',
    placeholder: 'placeholder-1',
    name: 'Mariana Costa',
    role: 'Mentora de Vendas',
    text: '"Sempre sofri com sites lentos que perdiam clientes no meio do caminho. A OCARECADEV resolveu isso e entregou uma verdadeira máquina de vendas."',
    anim: 'anim-scale',
    delay: 'delay-300',
  },
  {
    initials: 'CM',
    placeholder: 'placeholder-2',
    name: 'Carlos Moura',
    role: 'Sócio, Agência XYZ',
    text: '"Ter um código limpo e analytics injetado certinho nos botões me economizou muito tempo. O tracking funciona perfeitamente."',
    anim: 'anim-right',
    delay: 'delay-400',
  },
];
---

<section id="social-proof" class="section-social section-fade-top section-fade-bottom" style="--fade-from: #010101;">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title scroll-animate"><span class="text-neon">Resultados</span> falam mais que qualquer promessa</h2>
      <ul class="section-subtitle-list scroll-animate delay-100">
        {benefits.map((benefit) => (
          <li>
            <span class="check-icon"><Icon name="check" size={15} stroke={3} /></span>
            <span set:html={benefit} />
          </li>
        ))}
      </ul>
    </div>

    <div class="mockup-container scroll-animate anim-scale delay-150">
      <BeforeAfterMockup />
    </div>

    <div class="proof-grid">
      {testimonials.map((t) => (
        <GlassCard class={`scroll-animate ${t.anim} ${t.delay}`}>
          <div class="proof-author">
            <div class={`avatar-placeholder ${t.placeholder}`}>{t.initials}</div>
            <div class="author-info">
              <h4>{t.name}</h4>
              <span>{t.role}</span>
            </div>
          </div>
          <p class="proof-text">{t.text}</p>
          <div class="stars">
            {Array.from({ length: 5 }).map(() => <Icon name="star" size={18} />)}
          </div>
        </GlassCard>
      ))}
    </div>
  </div>
</section>

<style>
  .section-social {
    padding: 4rem 0;
    position: relative;
    background-color: #010101;
  }

  @media (min-width: 768px) {
    .section-social {
      padding: 6rem 0;
    }
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 0 1rem;
    position: relative;
    z-index: 10;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text-primary);
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: 3rem;
    }
  }

  .section-subtitle-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    align-items: center;
  }

  @media (min-width: 768px) {
    .section-subtitle-list {
      flex-direction: row;
      justify-content: center;
      gap: 2rem;
    }
  }

  .section-subtitle-list li {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .check-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    border-radius: 50%;
    color: var(--color-primary-neon);
    background: rgba(0, 255, 157, 0.1);
    border: 1px solid rgba(0, 255, 157, 0.3);
  }

  .mockup-container {
    max-width: 760px;
    margin: 0 auto 4rem;
    padding: 0 0.5rem;
  }

  .proof-grid {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .proof-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .proof-author {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .avatar-img {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid var(--color-primary-neon);
    object-fit: cover;
  }

  .avatar-placeholder {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid var(--glass-border);
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary, #ffffff);
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: 1px;
  }

  .placeholder-0 {
    background: linear-gradient(to top right, #00FF9D, #00663d);
    border-color: #00E58B;
  }

  .placeholder-1 {
    background: linear-gradient(to top right, #3b82f6, #7c3aed);
    border-color: #00A666;
  }

  .placeholder-2 {
    background: linear-gradient(to top right, #4ade80, #3b82f6);
  }

  .author-info h4 {
    color: var(--color-text-primary);
    font-weight: 700;
    font-size: 1.1rem;
    margin: 0;
  }

  .author-info span {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  .proof-text {
    color: #e5e5e5;
    font-style: italic;
    line-height: 1.6;
  }

  .stars {
    color: var(--color-primary-neon);
    margin-top: 1rem;
    display: flex;
    gap: 3px;
  }


