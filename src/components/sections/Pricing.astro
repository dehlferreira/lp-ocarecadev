---
import GlassCard from '../ui/GlassCard.astro';
import Button from '../ui/Button.astro';

const whatsappNumber = import.meta.env.WHATSAPP_NUMBER || '5511999999999';
---

<section id="pricing" class="section-pricing section-fade-top">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title scroll-animate">Escolha o plano ideal para o seu momento</h2>
    </div>

    <div class="pricing-grid">
      <!-- Plano 1 -->
      <GlassCard class="scroll-animate delay-200 pricing-card">
        <h3 class="plan-name">OCARECADEV EXPRESS</h3>
        <p class="plan-desc">Para quem precisa entrar no ar rápido.</p>
        <div class="plan-price">
          R$ 297<span>/único</span>
        </div>
        <p class="plan-installments">ou 12x de R$ 24,75 sem juros</p>
        <ul class="plan-features">
          <li>✓ Landing page simples</li>
          <li>✓ Template validado</li>
          <li>✓ Personalização básica</li>
          <li>✓ Botão direto para WhatsApp</li>
          <li>✓ Entrega em até 48h</li>
        </ul>
        <Button type="ghost" class="btn-full btn-pricing-cta" href={`https://wa.me/${whatsappNumber}?text=Olá, tenho interesse no plano EXPRESS`}>
          Quero começar rápido
        </Button>
      </GlassCard>

      <!-- Plano 2 (Destaque) -->
      <GlassCard class="scroll-animate delay-300 pricing-card highlight-card" highlight={true}>
        <div class="recommended-badge">Recomendado</div>
        <h3 class="plan-name">LANDING QUE VENDE</h3>
        <p class="plan-desc">Para quem quer gerar <span class="text-neon">clientes</span> de verdade.</p>
        <div class="plan-price text-gradient">
          R$ 997<span>/único</span>
        </div>
        <p class="plan-installments highlight-installments">ou 12x de R$ 83,08 sem juros</p>
        <ul class="plan-features text-bright">
          <li>✓ Estrutura focada em conversão</li>
          <li>✓ Design premium</li>
          <li>✓ CTA estratégico</li>
          <li>✓ Integração WhatsApp e Analytics</li>
          <li>✓ Tracking de cliques e leads</li>
          <li>✓ 1 revisão estratégica</li>
        </ul>
        <Button type="primary" class="btn-full btn-pricing-cta" href={`https://wa.me/${whatsappNumber}?text=Olá, tenho interesse no plano LANDING QUE VENDE`}>
          Quero uma página que gera clientes
        </Button>
      </GlassCard>

      <!-- Plano 3 -->
      <GlassCard class="scroll-animate delay-400 pricing-card">
        <h3 class="plan-name">MÁQUINA DE CLIENTES</h3>
        <p class="plan-desc">Para quem quer presença profissional e escala.</p>
        <div class="plan-price">
          R$ 2.497<span>/único</span>
        </div>
        <p class="plan-installments">ou 12x de R$ 208,08 sem juros</p>
        <ul class="plan-features">
          <li>✓ 3 a 5 páginas completas</li>
          <li>✓ Estrutura estratégica</li>
          <li>✓ Integrações e tracking</li>
          <li>✓ Pronto para tráfego pago</li>
          <li>✓ Otimização de conversão</li>
        </ul>
        <Button type="ghost" class="btn-full btn-pricing-cta" href={`https://wa.me/${whatsappNumber}?text=Olá, tenho interesse no plano MÁQUINA DE CLIENTES`}>
          Quero um sistema completo
        </Button>
      </GlassCard>
    </div>
  </div>
</section>

<style>
  .section-pricing {
    padding: 4rem 0;
    position: relative;
    background-color: #030303;
  }

  @media (min-width: 768px) {
    .section-pricing {
      padding: 6rem 0;
    }
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 0 1rem;
    position: relative;
    z-index: 10;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text-primary);
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: 3rem;
    }
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
  }

  .pricing-grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Cards Internos */
  :global(.pricing-card) {
    height: fit-content;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .recommended-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--color-primary-neon), #00A666);
    color: var(--color-bg-dark);
    padding: 0.4rem 1.2rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    box-shadow: 0 4px 15px rgba(0, 255, 157, 0.3);
    white-space: nowrap;
    z-index: 10;
  }

  :global(.highlight-card) {
    transform: scale(1.05);
    z-index: 10;
  }

  .plan-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .plan-desc {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }

  .plan-price {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text-primary);
    margin: 1.5rem 0;
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .plan-price {
      font-size: 2.5rem;
    }
  }

  .plan-installments {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    margin-bottom: 2.5rem;
    font-weight: 500;
  }

  .highlight-installments {
    color: var(--color-primary-neon);
    font-weight: 600;
  }

  .plan-price span {
    font-size: 1.125rem;
    font-weight: 400;
    color: #9ca3af;
  }

  .text-gradient {
    color: transparent;
    background-image: linear-gradient(to right, var(--color-primary-neon), #00A666);
    background-clip: text;
    -webkit-background-clip: text;
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
    flex-grow: 1;
    color: #d1d5db;
  }

  .plan-features li {
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .text-bright li {
    color: #f3f4f6;
    font-weight: 600;
  }

  .plan-features .disabled {
    opacity: 0.4;
  }

  :global(.btn-full) {
    width: 100%;
    justify-content: center;
  }
</style>
