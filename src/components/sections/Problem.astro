---
import Icon from '../ui/Icon.astro';

const pains = [
  'Seu site não gera <span class="text-neon">leads</span>',
  'Ninguém clica no seu botão',
  'Você depende de indicação',
  'E quando não indicam… você não vende',
];
const delays = ['delay-100', 'delay-150', 'delay-200', 'delay-300'];
---

<section id="problema" class="section-problem section-fade-top section-fade-bottom">
  <div class="container">
    <div class="problem-content">
      <h2 class="problem-title scroll-animate">
        Se você já tem um site e ele não te traz <span class="text-neon">clientes</span>,
        ele não serve pra nada.
      </h2>

      <p class="problem-desc scroll-animate delay-100">A verdade é simples:</p>

      <ul class="problem-list">
        {pains.map((pain, i) => (
          <li class={`scroll-animate anim-rise-sm ${delays[i]}`}>
            <span class="pain-icon"><Icon name="x" size={16} stroke={2.5} /></span>
            <span set:html={pain} />
          </li>
        ))}
      </ul>

      <p class="problem-highlight scroll-animate anim-scale delay-400">
        <span class="highlight-icon"><Icon name="arrow-right" size={20} stroke={2.5} /></span>
        você nem sabe o que está errado
      </p>
    </div>
  </div>
</section>

<style>
  .section-problem {
    padding: 4rem 0;
    position: relative;
    background-color: #030303;
  }

  @media (min-width: 768px) {
    .section-problem {
      padding: 8rem 0;
    }
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
    padding: 0 1rem;
    position: relative;
    z-index: 10;
    text-align: center;
  }

  .problem-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text-primary);
    line-height: 1.2;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .problem-title {
      font-size: 3rem;
    }
  }

  .problem-desc {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }

  .problem-list {
    list-style: none;
    padding: 0;
    margin: 0 auto 2.5rem;
    display: inline-flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
    font-size: 1.125rem;
    color: #e5e5e5;
  }

  .problem-list li {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  /* Badge circular para o "x" — vermelho dessaturado, sóbrio (não emoji) */
  .pain-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    flex-shrink: 0;
    border-radius: 50%;
    color: #ff6b6b;
    background: rgba(255, 107, 107, 0.1);
    border: 1px solid rgba(255, 107, 107, 0.25);
  }

  .problem-highlight {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.6rem;
  }

  .highlight-icon {
    display: inline-flex;
    color: var(--color-primary-neon);
  }

  @media (min-width: 768px) {
    .problem-highlight {
      font-size: 1.5rem;
    }
  }
</style>
