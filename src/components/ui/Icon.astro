---
export interface Props {
  name: string;
  class?: string;
  size?: number | string;
  stroke?: number;
  [x: string]: any;
}

const { name, class: className, size = 24, stroke = 2, ...rest } = Astro.props;

// Lucide-style SVG paths. Stroke-based icons use currentColor; `star` is filled.
const ICONS: Record<string, { body: string; filled?: boolean }> = {
  check: { body: '<path d="M20 6 9 17l-5-5"/>' },
  x: { body: '<path d="M18 6 6 18"/><path d="m6 6 12 12"/>' },
  'arrow-right': { body: '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>' },
  spark: {
    body: '<path d="M12 3v3"/><path d="M12 18v3"/><path d="m5.6 5.6 2.1 2.1"/><path d="m16.3 16.3 2.1 2.1"/><path d="M3 12h3"/><path d="M18 12h3"/><path d="m5.6 18.4 2.1-2.1"/><path d="m16.3 7.7 2.1-2.1"/>',
  },
  star: {
    filled: true,
    body: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
  },
  'layout-template': {
    body: '<rect width="18" height="7" x="3" y="3" rx="1"/><rect width="9" height="7" x="3" y="14" rx="1"/><rect width="5" height="7" x="16" y="14" rx="1"/>',
  },
  'sliders-horizontal': {
    body: '<line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="16" x2="16" y1="18" y2="22"/>',
  },
  rocket: {
    body: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91 0z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
  },
  'trending-up': {
    body: '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
  },
  'trending-down': {
    body: '<polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/>',
  },
};

const icon = ICONS[name] ?? ICONS.check;
---

<svg
  class:list={['icon', className]}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={icon.filled ? 'currentColor' : 'none'}
  stroke={icon.filled ? 'none' : 'currentColor'}
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={icon.body}
  {...rest}
/>

<style>
  .icon {
    display: inline-block;
    flex-shrink: 0;
    vertical-align: middle;
  }
</style>
