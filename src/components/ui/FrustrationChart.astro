---
// Mockup CSS/SVG: tela escura com gráfico de performance em queda (tom de dor).
// Sem texto em inglês — substitui a imagem gerada por IA `frustration-screen`.
import Icon from './Icon.astro';
---

<div class="frustration-mockup">
  <div class="screen">
    <!-- Barra do "navegador" -->
    <div class="screen-bar">
      <span class="dot"></span>
      <span class="dot"></span>
      <span class="dot"></span>
      <div class="fake-url">
        <span class="url-bullet"></span>
        <span class="url-line"></span>
      </div>
    </div>

    <!-- Conteúdo: dashboard com gráfico em queda -->
    <div class="screen-body">
      <div class="dash-head">
        <div class="dash-title">
          <span class="bar w-28"></span>
          <span class="bar w-16 dim"></span>
        </div>
        <span class="trend-down"><Icon name="trending-down" size={14} stroke={2.5} /> -68%</span>
      </div>

      <div class="chart">
        <svg viewBox="0 0 320 140" preserveAspectRatio="none" aria-hidden="true">
          <!-- grid -->
          <line x1="0" y1="35" x2="320" y2="35" class="grid" />
          <line x1="0" y1="70" x2="320" y2="70" class="grid" />
          <line x1="0" y1="105" x2="320" y2="105" class="grid" />
          <!-- área sob a linha -->
          <path
            d="M0,30 L60,45 L120,40 L180,75 L240,95 L320,128 L320,140 L0,140 Z"
            class="area"
          />
          <!-- linha em queda -->
          <path
            d="M0,30 L60,45 L120,40 L180,75 L240,95 L320,128"
            class="line"
          />
          <circle cx="320" cy="128" r="4" class="end-dot" />
        </svg>
      </div>

      <div class="stats">
        <div class="stat">
          <span class="bar w-10"></span>
          <span class="bar w-20 dim"></span>
        </div>
        <div class="stat">
          <span class="bar w-10"></span>
          <span class="bar w-16 dim"></span>
        </div>
        <div class="stat">
          <span class="bar w-10"></span>
          <span class="bar w-24 dim"></span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .frustration-mockup {
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
    perspective: 1200px;
  }

  .screen {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    background: #0d0f12;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.6),
      0 0 50px rgba(255, 60, 60, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .screen-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 0.9rem;
    background: #15181d;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
  }

  .fake-url {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex: 1;
    margin-left: 0.6rem;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 6px;
    padding: 0.3rem 0.6rem;
  }

  .url-bullet {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255, 80, 80, 0.7);
  }

  .url-line {
    height: 5px;
    width: 45%;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.12);
  }

  .screen-body {
    padding: 1.4rem 1.4rem 1.6rem;
  }

  .dash-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.4rem;
  }

  .dash-title {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .bar {
    display: block;
    height: 8px;
    border-radius: 5px;
    background: rgba(255, 255, 255, 0.3);
  }

  .bar.dim {
    background: rgba(255, 255, 255, 0.12);
    height: 6px;
  }

  .w-10 { width: 22px; }
  .w-16 { width: 56px; }
  .w-20 { width: 78px; }
  .w-24 { width: 96px; }
  .w-28 { width: 112px; }

  .trend-down {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 700;
    color: #ff5c5c;
    background: rgba(255, 60, 60, 0.1);
    border: 1px solid rgba(255, 60, 60, 0.25);
    border-radius: 8px;
    padding: 0.25rem 0.6rem;
    white-space: nowrap;
  }

  .chart {
    height: 150px;
    margin-bottom: 1.4rem;
  }

  .chart svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .grid {
    stroke: rgba(255, 255, 255, 0.05);
    stroke-width: 1;
  }

  .area {
    fill: url(#fall-grad);
    fill: rgba(255, 60, 60, 0.12);
  }

  .line {
    fill: none;
    stroke: #ff5c5c;
    stroke-width: 2.5;
    stroke-linejoin: round;
    stroke-linecap: round;
    filter: drop-shadow(0 0 6px rgba(255, 60, 60, 0.6));
  }

  .end-dot {
    fill: #ff5c5c;
    filter: drop-shadow(0 0 6px rgba(255, 60, 60, 0.8));
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.9rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 0.8rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 10px;
  }
</style>
